# Server
PORT=3000

# Nettstedets URL (sett til din Railway-domene i produksjon)
SITE_URL=https://din-app.up.railway.app

# VAPID-nøkler for push-varsler
# Genereres automatisk ved første oppstart hvis de ikke er satt.
# Kopier nøklene fra server-loggen og lim inn som miljøvariabler i Railway.
VAPID_PUBLIC=
VAPID_PRIVATE=
